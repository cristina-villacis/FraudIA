# ============================================
# PLANTILLA — Este archivo SÍ se sube a Git (sin claves reales).
# Al desplegar: copie a .env en el servidor y complete los valores.
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)
# ============================================

# Base de datos (TiDB Cloud / MySQL / SQLite local)
# TiDB Cloud: Connect → Public endpoint → sustituir HOST, USUARIO, PASSWORD
# Instancia ejemplo: Siniestros (us-east-1)
DATABASE_URL=mysql+pymysql://USUARIO:PASSWORD@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/fraudia_claims
# DATABASE_URL=sqlite:///data/fraudia_claims.db
# MYSQL_SSL=true

FLASK_APP=src.app.main
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=cambiar-por-un-secreto-aleatorio

DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_SYNTHETIC_PATH=data/synthetic

MODEL_PATH=src/models/saved/
MODEL_VERSION=v1.0

POWERBI_EXPORT_PATH=data/processed/powerbi_export.xlsx

NLP_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SIMILARITY_THRESHOLD=0.70

# OpenAI / ChatGPT — pegar clave en .env local o en Vercel → Environment Variables
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=true

# Vercel (opcional en local; Vercel lo define automáticamente)
# VERCEL=1

# Seguridad API en Vercel (opcional):
# Si se define, las rutas /api/* requieren header: X-Vercel-API-Key
VERCEL_API_KEY=
