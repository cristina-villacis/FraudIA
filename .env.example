# Copiar a .env para desarrollo local
# copy .env.example .env
#
# TiDB Cloud — cluster "Aseguradora" (Starter, us-east-1)
# Instance ID: 10822779121986106989
# En el panel Connect aparece DATABASE=sys; la app crea y usa fraudia_claims

TIDB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=ezF1nSTkhwhsAAD.root
TIDB_PASSWORD=TU_PASSWORD_DESDE_TIDB_CLOUD
TIDB_DATABASE=fraudia_claims
# TIDB_SSL_CA=certs/isrgrootx1.pem

FLASK_PORT=5001
APP_URL=http://localhost:5001
SECRET_KEY=cambiar-por-un-secreto-aleatorio

PERSIST_DATASET_ON_LOAD=true
AUTO_PIPELINE_ON_LOAD=true
PIPELINE_ASYNC=true
SCORE_SYNC_ON_PIPELINE=true
NLP_MAX_ROWS=2000
MYSQL_CONNECT_TIMEOUT=8

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=true

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENABLED=true
LLM_PROVIDER=auto

# Vercel → Settings → Environment Variables (NO subir a Git):
# DATABASE_URL=mysql+pymysql://ezF1nSTkhwhsAAD.root:PASSWORD@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/fraudia_claims
