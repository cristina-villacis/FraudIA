# Copiar a .env para desarrollo local (TiDB Fraulocal)
# copy .env.example .env

TIDB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=TU_USUARIO.root
TIDB_PASSWORD=TU_PASSWORD
TIDB_DATABASE=fraudia_claims
# TIDB_SSL_CA=certs/isrgrootx1.pem

FLASK_PORT=5001
APP_URL=http://localhost:5001
SECRET_KEY=cambiar-por-un-secreto-aleatorio

# Guardar tablas en TiDB al ejecutar el análisis (tras subir Excel)
PERSIST_DATASET_ON_LOAD=true
# Análisis automático tras subir Excel
AUTO_PIPELINE_ON_LOAD=true
# Pipeline en segundo plano (no bloquea la subida)
PIPELINE_ASYNC=true
# Escribir scores en siniestros tras el análisis (por defecto si PERSIST=true)
SCORE_SYNC_ON_PIPELINE=true
# Máximo de filas para similitud NLP (evita O(n²) en datasets grandes)
NLP_MAX_ROWS=2000
MYSQL_CONNECT_TIMEOUT=8

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ENABLED=true

# Vercel (solo en el panel de Vercel, no en .env local):
# DATABASE_URL=mysql+pymysql://USUARIO:PASSWORD@HOST:4000/fraudia_claims
