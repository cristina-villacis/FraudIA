{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": [
        "data/processed/**",
        "data/synthetic/**",
        "src/app/templates/**",
        "src/app/static/**"
      ]
    }
  }
}
